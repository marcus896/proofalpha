# ProofAlpha bootstrap has no required secrets.
# Future optional model-provider and exchange variables must remain unset for the safe demo.

PROOFALPHA_MODE=paper
PROOFALPHA_TELEMETRY=off
PROOFALPHA_BIND_HOST=127.0.0.1
PROOFALPHA_LOG_LEVEL=INFO

# Never enable or document real credentials in public examples.
# OPENAI_API_KEY=
# EXCHANGE_API_KEY=
# EXCHANGE_API_SECRET=
